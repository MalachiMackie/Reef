fn array_filter_map<T>(arr: [option::<T>]): [T] {
    var mut items = list::create();
    for (var i = 0; i < arr.length; i++) {
        if (arr[i] matches option::Some(var value)) {
            items.add(value);
        }
    }
    return items.reset_and_get_items();
}

