extern fn string_sub_string(original: string, offset: u64, length: u64): string

pub unboxed class string_slice {
    // todo: pub(module)
    pub field original_string: string,
    pub field offset: u64,
    pub field length: u64,

    pub fn slice(start: u64, new_length: u64): mut result::<string_slice, string> {
        if (start + new_length > length) {
            return error("string_slice slice out of bounds");
        }

        return ok(new string_slice {
            original_string = original_string,
            offset = offset + start,
            length = new_length
        });
    }

    pub fn to_string(): string {
        if (length == 0) {
            return "";
        }

        if (offset == 0 && length == original_string.length) {
            return original_string;
        }

        return string_sub_string(original_string, offset, length);
    }

    pub fn char_at(at: u64): option::<char>
    {
        return original_string.char_at(at + offset);
    }

    pub fn eq_string(str: string): bool
    {
        if (str.length != length) {
            return false;
        }
        if (length == 0) {
            return true;
        }
        if (offset == 0 && length == str.length) {
            return original_string.eq(str);
        }

        for (var i = 0; i < length; i++) {
            if (char_at(i) != str.char_at(i)) {
                return false;
            }
        }

        return true;
    }

    pub fn starts_with_string(str: string): bool {
        print_string("todo - starts_with_string");
        return todo!;
    }

    pub fn starts_with_char(ch: char): bool {
        print_string("todo - starts_with_char");
        return todo!;
    }

    pub fn starts_with_slice(other: string_slice): bool {
        print_string("todo - starts_with_slice");
        return todo!;
    }

    pub fn ends_with_char(ch: char): bool {
        print_string("todo - ends_with_char");
        return todo!;
    }

    pub fn ends_with_string(str: string): bool {
        print_string("todo - ends_with_string");
        return todo!;
    }

    pub fn contains_string(str: string): bool {
        print_string("todo - contains_string");
        return todo!;
    }

    pub fn contains_any_except_chars(chars: [char]): bool {
        print_string("todo - contains_any_except_chars");
        return todo!;
    }

    pub fn last_index_of_char(ch: char): option::<u64> {
        print_string("todo - last_index_of_char");
        return todo!;
    }

    pub fn trim_end_char(ch: char): string_slice {
        print_string("todo - trim_end_char");
        return todo!;
    }
}

// private global function for easy ffi naming
extern fn string_chars(str: string): [char]
extern fn string_char_at(str: string, at: u64): char
extern fn string_concat(left: string, right: string): string;

#[boxed_only]
pub class string {
    // If these are renamed or reordered, serialization within AssemblyLine needs to be updated wherever we write strings
    pub field length: u64,
    pub field start_byte: u8,

    pub fn slice(start: u64, slice_length: u64): result::<string_slice, string> {
        if (start + slice_length > length) {
            return error("String slice out of bounds");
        }

        return ok(new string_slice {
            original_string = this,
            offset = start,
            length = slice_length
        });
    }

    pub fn chars(): [char] {
        return string_chars(this);
    }

    pub fn as_slice(): string_slice {
        return new string_slice {
            original_string = this,
            offset = 0,
            length = length,
        };
    }

    pub fn char_at(at: u64): option::<char>
    {
        if (length < at)
        {
            return option::None;
        }

        return option::Some(string_char_at(this, at));
    }

    pub fn eq(other: string): bool
    {
        if (ref_equals(this, other)) {
            return true;
        }
        if (other.length != length)
        {
            return false;
        }
        if (length == 0)
        {
            return true;
        }
        if (start_byte != other.start_byte)
        {
            return false;
        }
        for (var i = 0; i < length; i++)
        {
            if (char_at(i) != other.char_at(i)) {
                return false;
            }
        }

        return true;
    }

    pub fn starts_with_slice(other_slice: string_slice): bool {
        if (other_slice.length > length) {
            return false;
        }

        for (var i = 0; i < other_slice.length; i++) {
            if (other_slice.char_at(i) != char_at(i)) {
                return false;
            }
        }

        return true;
    }

    pub fn concat(other: string): string {
        if (this.eq("")) {
            return other;
        }
        if (other.eq("")) {
            return this;
        }

        return string_concat(this, other);
    }
}

