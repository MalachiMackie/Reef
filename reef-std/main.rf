pub unboxed union option<TValue> {
    None,
    Some(TValue),

    pub fn unwrap(): TValue {
        return match(this) {
            Self::None => panic(),
            Self::Some(var value) => value,
        };
    }

    pub fn ok_or<TError>(err: TError): result::<TValue, TError> {
        return match (this)
        {
            Self::Some(var value) => ok(value),
            Self::None => error(err),
        };
    }
}

pub unboxed union result<TValue, TError> {
    Ok(TValue),
    Error(TError),

    pub fn unwrap(): TValue {
        return match (this) {
            Self::Ok(var value) => value,
            Self::Error => {
                print_string("unwrap");
                panic();
                grab todo!;
            }
        };
    }
}

