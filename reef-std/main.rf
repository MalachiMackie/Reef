pub extern fn allocate_new_string(length: u64): mut string

// destination up until destination_char_offset must be filled with valid utf8 code points
pub extern fn unsafe_copy_string(destination: string, destination_char_offset: u64, source: string, source_char_offset: u64, length: u64)

