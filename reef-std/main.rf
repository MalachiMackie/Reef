use :::Reef:::Core:::Reflection:::TypeId;

pub class Function_1<TReturn> {
    pub field FunctionReference: methodPointer,
    pub field FunctionParameter: option::<rawPointer>,

    pub fn Call(): TReturn {
        return match (FunctionParameter) {
            option::Some(var x) => FunctionReference(x),
            option::None => FunctionReference(),
        };
    }
}

pub class Function_2<TParam, TReturn> {
    pub field FunctionReference: methodPointer,
    pub field FunctionParameter: option::<rawPointer>,

    pub fn Call(param: TParam): TReturn {
        return match (FunctionParameter) {
            option::Some(var x) => FunctionReference(x, param),
            option::None => FunctionReference(param),
        };
    }
}

pub class Function_3<TParam1, TParam2, TReturn> {
    pub field FunctionReference: methodPointer,
