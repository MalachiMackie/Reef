// intrinsic
pub extern fn sizeof<T>(): u64;
pub extern fn type_id_of<T>(): TypeId;

// todo: should be able to do: `var filled_array = [value; length];`
pub fn fill_dynamic_array<TValue>(length: u64, mut value: TValue): mut [TValue] {
    var mut bytes = unsafe_allocate_array_bytes(
        new ObjectHeader {
            TypeId = type_id_of::<TValue>(),
        },
        sizeof::<TValue>(),
        length);

    var mut array = from_bytes::<[TValue]>(bytes);

    var mut i = 0;
    while (i < length)
    {
        array[i] = value;
        i = i + 1;
    }

    return array;
}

class CatchUnwindData<TReturn> {
    pub field callee_fn: Fn(): TReturn,
    pub mut field return_value: option::<TReturn>,
}

fn do_call<TReturn>(data_bytes: [u8]) {
    var mut data = from_bytes::<CatchUnwindData::<TReturn>>(data_bytes);

    var result = data.callee_fn();
    data.return_value = option::Some(result);
}

pub fn catch_unwind<TResult>(callee: Fn(): TResult): result::<TResult, ()> {
    var data = new CatchUnwindData::<TResult> {
        callee_fn = callee,
        return_value = option::None
    };

    var data_bytes = as_bytes(data);

    if (catch_unwind_intrinsic(do_call::<TResult>, data_bytes)
        && data.return_value matches option::Some(var return_value)) {
        return ok(return_value);
    }

    return error(());
}

