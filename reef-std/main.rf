pub class list<TValue>
{
    mut field _inner_array: [TValue],
    mut field _length: u64,
    mut field _capacity: u64,

    pub fn length(): u64
    {
        return _length;
    }

    pub fn capacity(): u64
    {
        return _capacity;
    }

    pub mut fn add(value: TValue) {
        if (_length >= _capacity) {
            _capacity = _capacity * 2;
            var mut new_array = create_array(_capacity);
            for (var i = 0; i < _length; i++) {
                new_array[i] = _inner_array[i];
            }
            _inner_array = new_array;
        }
        _inner_array[_length++] = value;
    }

    pub fn get(index: u64): option::<TValue> {
        if (index < _length)
        {
            return option::Some(_inner_array[index]);
        }
        return option::None;
    }

    pub mut fn reset_and_get_items(): mut [TValue] {
        if (_capacity > _length) {
            // todo: shrink allocation
            unsafe_set_array_length(_inner_array, _length);
        }
        var mut items = _inner_array;
        _length = 0;
        _capacity = 4;
        _inner_array = create_array(_capacity);

        return items;
    }

    pub static fn create(): mut list::<TValue>
    {
        var mut capacity = 4;
        var mut inner_array = create_array(capacity);

        return new list::<TValue>
        {
            _inner_array = inner_array,
            _length = 0,
            _capacity = capacity,
        };
    }

    static fn create_array(capacity: u64): mut [TValue]
    {
        var mut bytes = unsafe_allocate_array_bytes(
            new ObjectHeader {
                TypeId = type_id_of::<TValue>(),
            },
            sizeof::<TValue>(),
            capacity);

        return from_bytes::<[TValue]>(bytes);
    }
}

// intrinsic
pub extern fn sizeof<T>(): u64;
pub extern fn type_id_of<T>(): TypeId;

// todo: should be able to do: `var filled_array = [value; length];`
pub fn fill_dynamic_array<TValue>(length: u64, mut value: TValue): mut [TValue] {
    var mut bytes = unsafe_allocate_array_bytes(
        new ObjectHeader {
            TypeId = type_id_of::<TValue>(),
        },
        sizeof::<TValue>(),
        length);

    var mut array = from_bytes::<[TValue]>(bytes);

    var mut i = 0;
    while (i < length)
    {
        array[i] = value;
        i = i + 1;
    }

    return array;
}

class CatchUnwindData<TReturn> {
    pub field callee_fn: Fn(): TReturn,
    pub mut field return_value: option::<TReturn>,
}

fn do_call<TReturn>(data_bytes: [u8]) {
    var mut data = from_bytes::<CatchUnwindData::<TReturn>>(data_bytes);

    var result = data.callee_fn();
    data.return_value = option::Some(result);
}

pub fn catch_unwind<TResult>(callee: Fn(): TResult): result::<TResult, ()> {
    var data = new CatchUnwindData::<TResult> {
        callee_fn = callee,
        return_value = option::None
    };

    var data_bytes = as_bytes(data);

    if (catch_unwind_intrinsic(do_call::<TResult>, data_bytes)
        && data.return_value matches option::Some(var return_value)) {
        return ok(return_value);
    }

    return error(());
}

pub attribute test{}
pub attribute boxed_only{}
